<view class="icon" style="width: {{sizePx}}; height: {{sizePx}}; color: {{color}}; display: inline-flex;">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="100%" height="100%"
       fill="{{fill ? color : 'none'}}"
       stroke="{{fill ? 'none' : color}}"
       stroke-width="{{fill ? 0 : 1.8}}"
       stroke-linecap="round" stroke-linejoin="round">
    <!-- menu -->
    <block wx:if="{{name === 'menu'}}">
      <line x1="3" y1="6" x2="21" y2="6" />
      <line x1="3" y1="12" x2="21" y2="12" />
      <line x1="3" y1="18" x2="21" y2="18" />
    </block>
    <!-- search -->
    <block wx:elif="{{name === 'search'}}">
      <circle cx="11" cy="11" r="7" />
      <line x1="20" y1="20" x2="16.5" y2="16.5" />
    </block>
    <!-- favorite -->
    <block wx:elif="{{name === 'favorite'}}">
      <path d="M12 21s-7-4.35-9.5-9C0.5 7 4 3 7.5 3c2 0 3.5 1 4.5 2.5C13 4 14.5 3 16.5 3 20 3 23.5 7 21.5 12 19 16.65 12 21 12 21z" />
    </block>
    <!-- star -->
    <block wx:elif="{{name === 'star'}}">
      <path d="M12 2.5l2.95 6.4 7.05.65-5.35 4.7 1.6 6.85L12 17.65 5.75 21.1l1.6-6.85L2 9.55l7.05-.65L12 2.5z" />
    </block>
    <!-- schedule -->
    <block wx:elif="{{name === 'schedule'}}">
      <circle cx="12" cy="12" r="9" />
      <polyline points="12 7 12 12 15 14" />
    </block>
    <!-- home -->
    <block wx:elif="{{name === 'home'}}">
      <path d="M3 11.5L12 4l9 7.5V20a1 1 0 0 1-1 1h-5v-6h-6v6H4a1 1 0 0 1-1-1z" />
    </block>
    <!-- query_stats -->
    <block wx:elif="{{name === 'query_stats'}}">
      <line x1="4" y1="20" x2="4" y2="10" />
      <line x1="10" y1="20" x2="10" y2="4" />
      <line x1="16" y1="20" x2="16" y2="14" />
      <line x1="20" y1="20" x2="2" y2="20" />
    </block>
    <!-- person -->
    <block wx:elif="{{name === 'person'}}">
      <circle cx="12" cy="8" r="4" />
      <path d="M4 21c0-4 4-7 8-7s8 3 8 7" />
    </block>
    <!-- add -->
    <block wx:elif="{{name === 'add'}}">
      <line x1="12" y1="5" x2="12" y2="19" />
      <line x1="5" y1="12" x2="19" y2="12" />
    </block>
    <!-- cloud_upload -->
    <block wx:elif="{{name === 'cloud_upload'}}">
      <path d="M7 18a4 4 0 0 1-1-7.9A6 6 0 0 1 18 9.5 4.5 4.5 0 0 1 18 18" />
      <polyline points="12 12 12 21" />
      <polyline points="8 16 12 12 16 16" />
    </block>
    <!-- analytics -->
    <block wx:elif="{{name === 'analytics'}}">
      <line x1="4" y1="20" x2="4" y2="10" />
      <line x1="10" y1="20" x2="10" y2="14" />
      <line x1="16" y1="20" x2="16" y2="6" />
      <line x1="20" y1="20" x2="2" y2="20" />
    </block>
    <!-- pie_chart -->
    <block wx:elif="{{name === 'pie_chart'}}">
      <path d="M21 12A9 9 0 1 1 12 3v9h9z" />
    </block>
    <!-- auto_awesome -->
    <block wx:elif="{{name === 'auto_awesome'}}">
      <path d="M12 2l1.8 4.6L18.5 8 13.8 9.5 12 14l-1.8-4.5L5.5 8l4.7-1.4L12 2z" />
      <path d="M19 14l.9 2.3L22 17l-2.1.7L19 20l-.9-2.3L16 17l2.1-.7L19 14z" />
    </block>
    <!-- lightbulb -->
    <block wx:elif="{{name === 'lightbulb'}}">
      <path d="M9 18h6" />
      <path d="M10 21h4" />
      <path d="M12 3a6 6 0 0 0-4 10.5c.6.7 1 1.6 1 2.5h6c0-.9.4-1.8 1-2.5A6 6 0 0 0 12 3z" />
    </block>
    <!-- restaurant -->
    <block wx:elif="{{name === 'restaurant'}}">
      <path d="M7 2v9a2 2 0 0 0 2 2h0a2 2 0 0 0 2-2V2" />
      <path d="M9 13v9" />
      <path d="M17 2c-2 0-3 2-3 5v5h3v9" />
    </block>
    <!-- verified -->
    <block wx:elif="{{name === 'verified'}}">
      <path d="M12 2l2.5 1.5L17.5 3l1 3 3 1.5-1.5 3 .5 3-3 1-1 3-3-1-2.5 1.5L8.5 17l-3 1-.5-3-3-1.5 1.5-3-1-3 3-1L6.5 3l3 .5L12 2z" />
      <polyline points="9 12 11 14 15 10" />
    </block>
    <!-- collections_bookmark -->
    <block wx:elif="{{name === 'collections_bookmark'}}">
      <rect x="3" y="3" width="14" height="14" rx="1" />
      <path d="M7 7h6" />
      <path d="M7 11h6" />
      <path d="M7 15h4" />
      <rect x="7" y="7" width="14" height="14" rx="1" transform="translate(2 0)" opacity="0.4" />
    </block>
    <!-- history -->
    <block wx:elif="{{name === 'history'}}">
      <path d="M3 12a9 9 0 1 0 3-6.7" />
      <polyline points="3 4 3 9 8 9" />
      <line x1="12" y1="7" x2="12" y2="12" />
      <line x1="12" y1="12" x2="15" y2="14" />
    </block>
    <!-- neurology (star/sparkle) -->
    <block wx:elif="{{name === 'neurology'}}">
      <path d="M12 3l1.5 4 4 1.5-4 1.5L12 14l-1.5-4-4-1.5 4-1.5L12 3z" />
      <path d="M19 14l.9 2.3L22 17l-2.1.7L19 20l-.9-2.3L16 17l2.1-.7L19 14z" />
    </block>
    <!-- chevron_right -->
    <block wx:elif="{{name === 'chevron_right'}}">
      <polyline points="9 6 15 12 9 18" />
    </block>
    <!-- settings -->
    <block wx:elif="{{name === 'settings'}}">
      <circle cx="12" cy="12" r="3" />
      <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33h0a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51h0a1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82v0a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
    </block>
    <!-- notifications -->
    <block wx:elif="{{name === 'notifications'}}">
      <path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9" />
      <path d="M13.7 21a2 2 0 0 1-3.4 0" />
    </block>
    <!-- help -->
    <block wx:elif="{{name === 'help'}}">
      <circle cx="12" cy="12" r="9" />
      <path d="M9.1 9a3 3 0 0 1 5.8 1c0 2-3 3-3 3" />
      <line x1="12" y1="17" x2="12.01" y2="17" />
    </block>
    <!-- logout -->
    <block wx:elif="{{name === 'logout'}}">
      <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
      <polyline points="16 17 21 12 16 7" />
      <line x1="21" y1="12" x2="9" y2="12" />
    </block>
    <!-- arrow_forward_ios -->
    <block wx:elif="{{name === 'arrow_forward_ios'}}">
      <polyline points="9 6 15 12 9 18" />
    </block>
    <!-- timer -->
    <block wx:elif="{{name === 'timer'}}">
      <line x1="10" y1="2" x2="14" y2="2" />
      <circle cx="12" cy="14" r="8" />
      <polyline points="12 10 12 14 15 16" />
    </block>
    <!-- eco -->
    <block wx:elif="{{name === 'eco'}}">
      <path d="M7 20c2-1 4-3 6-5 3-3 4-6 4-10-4 0-7 1-10 4-2 2-3 5-3 8" />
      <path d="M3 20c0-3 1-5 3-7" />
    </block>
    <!-- bakery_dining -->
    <block wx:elif="{{name === 'bakery_dining'}}">
      <path d="M3 17h18" />
      <path d="M5 17V11a3 3 0 0 1 3-3h8a3 3 0 0 1 3 3v6" />
      <path d="M9 8V4a3 3 0 0 1 6 0v4" />
    </block>
    <!-- egg_alt -->
    <block wx:elif="{{name === 'egg_alt'}}">
      <path d="M12 3c-4 0-7 5-7 9a7 7 0 0 0 14 0c0-4-3-9-7-9z" />
    </block>
    <!-- local_cafe -->
    <block wx:elif="{{name === 'local_cafe'}}">
      <path d="M18 8h1a4 4 0 0 1 0 8h-1" />
      <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4z" />
      <line x1="6" y1="1" x2="6" y2="4" />
      <line x1="10" y1="1" x2="10" y2="4" />
      <line x1="14" y1="1" x2="14" y2="4" />
    </block>
    <!-- fastfood -->
    <block wx:elif="{{name === 'fastfood'}}">
      <path d="M3 12h18" />
      <path d="M7 12v-4a2 2 0 0 1 4 0v4" />
      <path d="M11 12v-2a2 2 0 0 1 4 0v2" />
      <path d="M3 18h18" />
    </block>
    <!-- close -->
    <block wx:elif="{{name === 'close'}}">
      <line x1="18" y1="6" x2="6" y2="18" />
      <line x1="6" y1="6" x2="18" y2="18" />
    </block>
    <!-- arrow_forward -->
    <block wx:elif="{{name === 'arrow_forward'}}">
      <line x1="5" y1="12" x2="19" y2="12" />
      <polyline points="12 5 19 12 12 19" />
    </block>
    <!-- trending_flat -->
    <block wx:elif="{{name === 'trending_flat'}}">
      <polyline points="3 12 7 8 11 12 21 2" />
      <polyline points="14 2 21 2 21 9" />
    </block>
    <!-- placeholder -->
    <block wx:else>
      <circle cx="12" cy="12" r="9" />
    </block>
  </svg>
</view>
